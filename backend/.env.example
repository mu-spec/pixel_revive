# PixelRevive Gemini backend
# Keep this key ONLY on Render/Northflank/Vercel. Never put it in Flutter.
GEMINI_API_KEY=

# Optional client secret. If you set this, also set the same value in Flutter CloudApiConfig.backendClientSecret.
CLIENT_SHARED_SECRET=

# Server config
PORT=3000
MAX_JSON_MB=25
MAX_IMAGE_MB=6
RATE_LIMIT_PER_MINUTE=120
DAILY_START_LIMIT_PER_IP=40
FAILURE_BLOCK_THRESHOLD=8
FAILURE_BLOCK_MINUTES=30

# Optional Gemini image model overrides.
# Use the exact model IDs shown in Google AI Studio if the defaults change.
GEMINI_FLASH_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_PRO_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_LITE_IMAGE_MODEL=gemini-3.1-flash-lite-image-preview

# Per-feature overrides if needed
# GEMINI_AUTO_MODEL=
# GEMINI_FACE_MODEL=
# GEMINI_UPSCALE_MODEL=
# GEMINI_DENOISE_MODEL=
# GEMINI_UNBLUR_MODEL=
# GEMINI_COLORIZE_MODEL=
# GEMINI_RESTORE_MODEL=
# GEMINI_BG_CLEANUP_MODEL=
# GEMINI_CARTOON_MODEL=
# GEMINI_AGE_MODEL=
# GEMINI_BABY_MODEL=
# GEMINI_BACKGROUND_CHANGE_MODEL=
# GEMINI_BROCCOLI_MODEL=
