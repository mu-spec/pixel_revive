# Server
PORT=8080
NODE_ENV=production

# Default provider: replicate or fal
DEFAULT_AI_PROVIDER=replicate

# Keep real tokens ONLY in your hosting provider's environment variables.
# Do not commit real values to GitHub.
REPLICATE_API_TOKEN=
FAL_API_KEY=

# Optional: if set, Flutter must send this value in x-pixelrevive-client header.
# This is a light anti-abuse check, not a replacement for Firebase Auth/App Check.
CLIENT_SHARED_SECRET=

# Upload/request safety
MAX_JSON_MB=25
MAX_IMAGE_MB=8
REQUEST_TIMEOUT_MS=55000

# Optional Replicate model overrides.
# Defaults are set in server.js. Use owner/model or owner/model:version.
# IMPORTANT: tencentarc/gfpgan is NOT an "official" Replicate model, so it MUST
# be called version-pinned (owner/model:VERSIONHASH) or you get HTTP 404.
# Real-ESRGAN and remove-bg ARE official models and work unpinned.
# REPLICATE_FACE_MODEL=tencentarc/gfpgan:0fbacf7afc6c144e5be9767cff80f25aff23e52b0708f17e20f9879b2f21516c
# REPLICATE_AUTO_MODEL=tencentarc/gfpgan:0fbacf7afc6c144e5be9767cff80f25aff23e52b0708f17e20f9879b2f21516c
# REPLICATE_UPSCALE_MODEL=nightmareai/real-esrgan
# REPLICATE_ENHANCE_MODEL=nightmareai/real-esrgan
# REPLICATE_BG_CLEANUP_MODEL=lucataco/remove-bg

# Optional Fal.ai model overrides.
# FAL_FACE_MODEL=fal-ai/codeformer
# FAL_RESTORE_MODEL=fal-ai/codeformer
# FAL_UPSCALE_MODEL=fal-ai/esrgan
# FAL_BG_CLEANUP_MODEL=fal-ai/imageutils/rembg
